# Copy this file to .env and fill in your keys (never commit .env to git)
# Get a FREE Gemini API key: https://aistudio.google.com/apikey

# --- Gemini (recommended — free cloud tier, no local model install) ---
GEMINI_API_KEY=your-gemini-key-here
GEMINI_FLASH_MODEL=gemini-3.5-flash
GEMINI_FAST_MODEL=gemini-3.1-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-2

# --- Pinecone (optional — use mock for local demo) ---
PINECONE_API_KEY=mock_pinecone_key
PINECONE_INDEX=fds-documents
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# --- OpenAI (optional fallback) ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4.1
# OPENAI_FAST_MODEL=gpt-4.1-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# --- Redis (query/comparison cache; use redis://redis:6379/0 in Docker) ---
REDIS_URL=redis://localhost:6379/0
QUERY_CACHE_TTL_SECONDS=3600

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# --- RAG tuning ---
CHUNK_SIZE_TOKENS=400
CHUNK_OVERLAP_TOKENS=60
PARENT_CHUNK_SIZE_TOKENS=1600
RETRIEVAL_TOP_K=20
RERANK_TOP_N=6
GROUNDING_CONFIDENCE_THRESHOLD=0.55

# --- Security / resilience ---
REQUEST_TIMEOUT_SECONDS=120
RATE_LIMIT_RPM=60
MAX_RETRIES=3

# --- Context engineering ---
MAX_CONTEXT_TOKENS=12000
CONVERSATION_SUMMARY_TRIGGER_TURNS=8
